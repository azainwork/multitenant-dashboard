generator client {
  provider = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())
  email String @unique
  name String 
  password  String
  role Role @default(VIEWER)
  createdAt DateTime @default(now())
}

model Business {
  id String @id @default(cuid())
  name String
  type BusinessType
  revenue Metric[]
  createdAt DateTime @default(now())
}

model Metric {
  id String @id @default(cuid())
  businessId String
  business Business @relation(fields: [businessId], references: [id])
  month String
  revenue Float
  expense Float
  customers Int
  createdAt DateTime @default(now())
}

model Transaction {
  id String @id @default(cuid())
  businessId String
  amount Float
  type TransactionType
  status TransactionStatus
  description String
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  VIEWER
}

enum BusinessType {
  FNB
  PROPERTY
  CARWASH
  ADVERTISING
  TECH
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  COMPLETED
  PENDING
  FAILED
}

